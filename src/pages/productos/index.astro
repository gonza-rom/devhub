---
import Layout from '../../layouts/Layout.astro';

const productos = [
  {
    slug: 'pos',
    nombre: 'DevHub POS',
    tagline: 'Sistema punto de venta',
    desc: 'Controlá ventas, stock e inventario desde cualquier dispositivo. Para negocios físicos que quieren control total sin pagar comisiones.',
    color: 'red',
    icon: 'fas fa-cash-register',
    demoUrl: 'https://devhub-pos.vercel.app/',
    demoLabel: 'Demo live',
    features: ['Punto de venta rápido', 'Stock en tiempo real', 'Caja y reportes', 'Desde celular o PC'],
    badge: null,
    mockupLines: [
      { label: 'Remera básica', value: '$8.500' },
      { label: 'Pantalón jean', value: '$22.000' },
      { label: 'Zapatillas', value: '$35.000' },
    ],
    mockupTotal: '$65.500',
    mockupBtn: 'Cobrar',
  },
  {
    slug: 'turnos',
    nombre: 'DevHub Turnos',
    tagline: 'Agenda online automática',
    desc: 'Tus clientes reservan 24/7 sin que estés al teléfono. Confirmaciones automáticas por WhatsApp y panel de agenda completo.',
    color: 'blue',
    icon: 'fas fa-calendar-check',
    demoUrl: 'https://wa.me/3834944727',
    demoLabel: 'Solicitar demo',
    features: ['Reservas online 24/7', 'Confirmación por WhatsApp', 'Panel de agenda', 'Múltiples servicios'],
    badge: null,
    mockupLines: [
      { label: '9:00  María G.', value: '✓' },
      { label: '10:30 Carlos R.', value: '✓' },
      { label: '12:00 Ana L.', value: '⏳' },
    ],
    mockupTotal: null,
    mockupBtn: '+ Nuevo turno',
  },
  {
    slug: 'gourmet',
    nombre: 'DevHub Gourmet',
    tagline: 'Control gastronómico total',
    desc: 'Mesas, pedidos, cocina y cobranza en una sola pantalla. Para restaurantes que quieren eliminar confusiones y servir más rápido.',
    color: 'amber',
    icon: 'fas fa-utensils',
    demoUrl: 'https://wa.me/3834944727',
    demoLabel: 'Consultar demo',
    features: ['Mapa de mesas en vivo', 'Pedidos por mesa', 'Carta digital QR', 'Caja integrada'],
    badge: 'Nuevo',
    mockupLines: [
      { label: 'Mesa 1 — 4 pers.', value: '$8.500' },
      { label: 'Mesa 3 — 2 pers.', value: '$3.200' },
      { label: 'Mesa 5 — 3 pers.', value: '$12.000' },
    ],
    mockupTotal: null,
    mockupBtn: 'Ver mesas',
  },
];

const colorMap: Record<string, Record<string, string>> = {
  red: {
    border: 'border-red-500/60',
    hoverBorder: 'hover:border-red-500',
    shadow: 'hover:shadow-red-500/10',
    bg: 'from-red-950/60',
    glow: 'rgba(220,38,38,0.15)',
    accent: 'text-red-400',
    badge: 'bg-red-600/20 text-red-300 border-red-500/30',
    badgeHover: 'hover:bg-red-600 hover:text-white hover:border-red-600',
    check: 'text-red-500',
    btn: 'bg-red-600 hover:bg-red-500',
    pill: 'bg-red-600/10 text-red-400 border-red-500/20',
    mockupHeader: 'text-red-400',
    mockupTotal: 'text-red-400',
    mockupBtn: 'bg-red-600/80',
    icon: 'bg-red-600/20 border-red-500/30',
  },
  blue: {
    border: 'border-blue-500/60',
    hoverBorder: 'hover:border-blue-500',
    shadow: 'hover:shadow-blue-500/10',
    bg: 'from-blue-950/60',
    glow: 'rgba(37,99,235,0.15)',
    accent: 'text-blue-400',
    badge: 'bg-blue-600/20 text-blue-300 border-blue-500/30',
    badgeHover: 'hover:bg-blue-600 hover:text-white hover:border-blue-600',
    check: 'text-blue-500',
    btn: 'bg-blue-600 hover:bg-blue-500',
    pill: 'bg-blue-600/10 text-blue-400 border-blue-500/20',
    mockupHeader: 'text-blue-400',
    mockupTotal: 'text-blue-400',
    mockupBtn: 'bg-blue-600/80',
    icon: 'bg-blue-600/20 border-blue-500/30',
  },
  amber: {
    border: 'border-amber-500/60',
    hoverBorder: 'hover:border-amber-500',
    shadow: 'hover:shadow-amber-500/10',
    bg: 'from-amber-950/60',
    glow: 'rgba(217,119,6,0.15)',
    accent: 'text-amber-400',
    badge: 'bg-amber-600/20 text-amber-300 border-amber-500/30',
    badgeHover: 'hover:bg-amber-600 hover:text-white hover:border-amber-600',
    check: 'text-amber-500',
    btn: 'bg-amber-600 hover:bg-amber-500',
    pill: 'bg-amber-600/10 text-amber-400 border-amber-500/20',
    mockupHeader: 'text-amber-400',
    mockupTotal: 'text-amber-400',
    mockupBtn: 'bg-amber-600/80',
    icon: 'bg-amber-600/20 border-amber-500/30',
  },
};

const comparativa = [
  { feature: 'Panel administrador', pos: true, turnos: true, gourmet: true },
  { feature: 'Desde celular/tablet/PC', pos: true, turnos: true, gourmet: true },
  { feature: 'Soporte y mantenimiento', pos: true, turnos: true, gourmet: true },
  { feature: 'Control de stock', pos: true, turnos: false, gourmet: false },
  { feature: 'Gestión de turnos online', pos: false, turnos: true, gourmet: false },
  { feature: 'Confirmación por WhatsApp', pos: false, turnos: true, gourmet: false },
  { feature: 'Control de mesas', pos: false, turnos: false, gourmet: true },
  { feature: 'Carta digital QR', pos: false, turnos: false, gourmet: true },
  { feature: 'Vista de cocina en tiempo real', pos: false, turnos: false, gourmet: true },
];
---

<Layout title="Productos DevHub — POS, Turnos y Gourmet | Sistemas para tu Negocio">

  <!-- Hero -->
  <section class="pt-32 pb-16 bg-dark relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_0%,_rgba(255,193,7,0.06)_0%,_transparent_60%)]"></div>
    <!-- Grid decorativo -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="container mx-auto px-4 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-primary/10 border border-primary/30 rounded-full text-primary text-sm font-semibold mb-6 animate-on-scroll opacity-0">
        <i class="fas fa-cube text-xs"></i>
        Plataformas DevHub
      </div>
      <h1 class="text-5xl md:text-7xl font-bold mb-6 font-display animate-on-scroll opacity-0">
        Sistemas listos para<br />
        <span class="text-primary">tu negocio</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10 animate-on-scroll opacity-0">
        No solo hacemos webs — desarrollamos productos propios que potencian cada plan. Conocé cada sistema antes de elegir.
      </p>
      <!-- Mini nav de productos -->
      <div class="flex flex-wrap justify-center gap-3 animate-on-scroll opacity-0">
        {productos.map(p => (
          <a href={`#${p.slug}`}
            class={`inline-flex items-center gap-2 px-4 py-2 rounded-full border text-sm font-semibold transition-all duration-300 hover:scale-105 ${colorMap[p.color].pill} ${colorMap[p.color].border}`}>
            <i class={`${p.icon} text-xs`}></i>
            {p.nombre}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Cards de productos -->
  <section class="py-20 bg-dark-secondary">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto space-y-8">

        {productos.map((p, i) => {
          const c = colorMap[p.color];
          const isEven = i % 2 === 0;
          return (
            <div id={p.slug}
              class={`group animate-on-scroll opacity-0 bg-dark rounded-2xl border ${c.border} ${c.hoverBorder} transition-all duration-500 ${c.shadow} hover:shadow-2xl overflow-hidden`}
              style={`animation-delay: ${i * 0.1}s`}>

              <div class={`grid grid-cols-1 lg:grid-cols-2 ${isEven ? '' : 'lg:grid-flow-col-dense'}`}>

                <!-- Mockup visual -->
                <div class={`relative h-64 lg:h-auto min-h-[280px] overflow-hidden flex items-center justify-center p-8 bg-gradient-to-br ${c.bg} to-dark ${isEven ? '' : 'lg:col-start-2'}`}>
                  <div class="absolute inset-0" style={`background: radial-gradient(ellipse at center, ${c.glow} 0%, transparent 70%)`}></div>
                  <!-- Número decorativo grande -->
                  <span class={`absolute text-[140px] font-black opacity-[0.04] right-4 bottom-0 leading-none font-display ${c.accent}`}>{String(i + 1).padStart(2, '0')}</span>

                  <!-- Mockup card -->
                  <div class="relative z-10 w-full max-w-[260px]">
                    <div class={`bg-dark/80 backdrop-blur-sm rounded-2xl border p-4 shadow-2xl border-${p.color === 'red' ? 'red' : p.color === 'blue' ? 'blue' : 'amber'}-500/20`}>
                      <div class="flex items-center gap-2 mb-4 pb-3 border-b border-white/5">
                        <div class={`w-6 h-6 rounded-lg flex items-center justify-center ${c.icon} border`}>
                          <i class={`${p.icon} ${c.accent} text-xs`}></i>
                        </div>
                        <span class={`font-bold text-xs ${c.accent} font-display`}>{p.nombre}</span>
                        {p.badge && (
                          <span class={`ml-auto text-[9px] px-2 py-0.5 rounded-full border font-semibold ${colorMap[p.color].badge}`}>{p.badge}</span>
                        )}
                      </div>
                      <div class="space-y-2 mb-4">
                        {p.mockupLines.map(line => (
                          <div class="flex justify-between items-center">
                            <span class="text-gray-400 text-[11px]">{line.label}</span>
                            <span class={`text-[11px] font-mono font-semibold ${line.value === '✓' ? 'text-green-400' : line.value === '⏳' ? 'text-yellow-400' : 'text-white'}`}>{line.value}</span>
                          </div>
                        ))}
                      </div>
                      {p.mockupTotal && (
                        <div class={`flex justify-between items-center mb-3 pt-2 border-t border-white/5`}>
                          <span class="text-gray-500 text-[10px]">Total</span>
                          <span class={`${c.mockupTotal} font-bold text-sm font-mono`}>{p.mockupTotal}</span>
                        </div>
                      )}
                      <div class={`${c.mockupBtn} text-white text-[11px] text-center py-2 rounded-xl font-semibold cursor-pointer`}>
                        {p.mockupBtn}
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Contenido -->
                <div class={`p-8 lg:p-12 flex flex-col justify-center ${isEven ? '' : 'lg:col-start-1'}`}>
                  <div class={`inline-flex items-center gap-2 px-3 py-1 rounded-full border text-xs font-semibold mb-4 w-fit ${c.pill} ${c.border}`}>
                    <i class={`${p.icon} text-xs`}></i>
                    {p.tagline}
                  </div>
                  <h2 class={`text-3xl md:text-4xl font-bold mb-4 font-display ${c.accent}`}>{p.nombre}</h2>
                  <p class="text-gray-300 mb-6 leading-relaxed text-lg">{p.desc}</p>

                  <ul class="grid grid-cols-2 gap-2 mb-8">
                    {p.features.map(f => (
                      <li class="flex items-center gap-2 text-sm text-gray-300">
                        <i class={`fas fa-check-circle ${c.check} text-xs flex-shrink-0`}></i>
                        {f}
                      </li>
                    ))}
                  </ul>

                  <div class="flex flex-wrap gap-3">
                    <a href={`/productos/${p.slug}`}
                      class={`inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-bold text-sm transition-all duration-300 hover:scale-105 border ${c.badge} ${c.badgeHover}`}>
                      <i class="fas fa-arrow-right text-xs"></i>
                      Ver página completa
                    </a>
                    <a href={p.demoUrl} target="_blank" rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-bold text-sm bg-dark-secondary border border-dark-tertiary text-gray-300 hover:text-white hover:border-gray-500 transition-all duration-300">
                      <i class={`${p.demoUrl.includes('wa.me') ? 'fab fa-whatsapp' : 'fas fa-external-link-alt'} text-xs`}></i>
                      {p.demoLabel}
                    </a>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Comparativa -->
  <section class="py-20 bg-dark">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 font-display animate-on-scroll opacity-0">
        ¿Cuál es para vos?
      </h2>
      <p class="text-center text-gray-400 mb-12 animate-on-scroll opacity-0">Comparativa rápida de funcionalidades</p>

      <div class="max-w-3xl mx-auto animate-on-scroll opacity-0 overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-dark-tertiary">
              <th class="text-left py-3 pr-4 text-gray-500 text-sm font-semibold w-1/2">Funcionalidad</th>
              <th class="text-center py-3 px-3 text-red-400 text-sm font-bold">POS</th>
              <th class="text-center py-3 px-3 text-blue-400 text-sm font-bold">Turnos</th>
              <th class="text-center py-3 px-3 text-amber-400 text-sm font-bold">Gourmet</th>
            </tr>
          </thead>
          <tbody>
            {comparativa.map((row, i) => (
              <tr class={`border-b border-dark-tertiary/50 ${i % 2 === 0 ? 'bg-dark-secondary/30' : ''}`}>
                <td class="py-3 pr-4 text-gray-300 text-sm">{row.feature}</td>
                <td class="text-center py-3 px-3">
                  {row.pos
                    ? <i class="fas fa-check text-green-400 text-sm"></i>
                    : <i class="fas fa-minus text-gray-700 text-sm"></i>}
                </td>
                <td class="text-center py-3 px-3">
                  {row.turnos
                    ? <i class="fas fa-check text-green-400 text-sm"></i>
                    : <i class="fas fa-minus text-gray-700 text-sm"></i>}
                </td>
                <td class="text-center py-3 px-3">
                  {row.gourmet
                    ? <i class="fas fa-check text-green-400 text-sm"></i>
                    : <i class="fas fa-minus text-gray-700 text-sm"></i>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-dark-secondary relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(255,193,7,0.05)_0%,_transparent_60%)]"></div>
    <div class="container mx-auto px-4 text-center relative z-10">
      <h2 class="text-3xl md:text-5xl font-bold mb-4 font-display animate-on-scroll opacity-0">
        Cada producto incluye <span class="text-primary">landing + soporte</span>
      </h2>
      <p class="text-gray-400 mb-10 max-w-xl mx-auto animate-on-scroll opacity-0">
        Los planes combinan tu página web con el sistema que necesitás. Todo desde $50.000/mes.
      </p>
      <div class="flex flex-wrap justify-center gap-4 animate-on-scroll opacity-0">
        <a href="/#planes"
          class="px-8 py-4 bg-primary text-dark font-bold rounded-xl hover:bg-primary-dark transition-all duration-300 hover:scale-105 flex items-center gap-3 text-lg">
          <i class="fas fa-tags"></i>
          Ver todos los planes
        </a>
        <a href="https://wa.me/3834944727" target="_blank" rel="noopener noreferrer"
          class="px-8 py-4 border-2 border-primary/50 text-primary font-bold rounded-xl hover:bg-primary/10 transition-all duration-300 flex items-center gap-3 text-lg">
          <i class="fab fa-whatsapp"></i>
          Hablar con un asesor
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  @keyframes scroll-reveal {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-on-scroll { animation: scroll-reveal 0.8s ease-out forwards; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('animate-on-scroll');
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -80px 0px' });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>