---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="DevHub Turnos — Sistema de Gestión de Turnos Online | DevHub Argentina">

  <!-- Hero Turnos -->
  <section class="pt-32 pb-20 bg-dark relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_40%_50%,_rgba(37,99,235,0.08)_0%,_transparent_60%)]"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <!-- Texto -->
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-blue-600/10 border border-blue-500/30 rounded-full text-blue-400 text-sm font-semibold mb-6">
              <i class="fas fa-calendar-check text-xs"></i>
              Agenda Online
            </div>
            <h1 class="text-5xl md:text-6xl font-bold mb-6 font-display leading-tight">
              <span class="text-blue-400">DevHub</span><br />
              <span class="text-white">Turnos</span>
            </h1>
            <p class="text-xl text-gray-300 mb-8 leading-relaxed">
              Tus clientes reservan sus turnos online sin que tenés que estar al teléfono. Confirmaciones automáticas y gestión de agenda desde cualquier dispositivo.
            </p>
            <div class="flex flex-wrap gap-4 mb-10">
              <a href="https://wa.me/3834944727" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3.5 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-500 transition-all duration-300 hover:scale-105">
                <i class="fab fa-whatsapp"></i>
                Solicitar demo
              </a>
              <a href="/#planes"
                class="inline-flex items-center gap-2 px-6 py-3.5 border-2 border-blue-500/50 text-blue-300 font-bold rounded-xl hover:bg-blue-600/10 transition-all duration-300">
                <i class="fas fa-tags"></i>
                Ver planes
              </a>
            </div>
            <!-- Stats -->
            <div class="grid grid-cols-3 gap-4 pt-8 border-t border-dark-tertiary">
              {[
                { n: '24/7', label: 'Reservas online' },
                { n: '0', label: 'Llamados perdidos' },
                { n: 'Auto', label: 'Confirmación WPP' },
              ].map(({ n, label }) => (
                <div>
                  <div class="text-2xl font-bold text-blue-400 font-display">{n}</div>
                  <div class="text-gray-500 text-sm">{label}</div>
                </div>
              ))}
            </div>
          </div>

          <!-- Mockup Turnos -->
          <div class="relative">
            <div class="bg-dark-secondary rounded-2xl border border-blue-500/20 p-6 shadow-2xl shadow-blue-500/5">
              <!-- Header -->
              <div class="flex items-center justify-between mb-5 pb-4 border-b border-dark-tertiary">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-blue-600/20 rounded-lg flex items-center justify-center border border-blue-500/30">
                    <i class="fas fa-calendar-check text-blue-400 text-sm"></i>
                  </div>
                  <span class="font-bold text-white font-display">DevHub Turnos</span>
                </div>
                <div class="flex gap-2">
                  <button class="text-xs px-3 py-1 bg-dark rounded-full border border-dark-tertiary text-gray-400">Hoy</button>
                  <button class="text-xs px-3 py-1 bg-blue-600/20 rounded-full border border-blue-500/30 text-blue-300">Semana</button>
                </div>
              </div>

              <!-- Agenda del día -->
              <div class="mb-4">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-gray-400 text-sm font-semibold">Martes 15 de julio</span>
                  <span class="text-blue-400 text-xs">6 turnos</span>
                </div>
                <div class="space-y-2">
                  {[
                    { hora: '9:00', nombre: 'María González', servicio: 'Corte de cabello', estado: 'confirmado', dur: '45 min' },
                    { hora: '10:00', nombre: 'Carlos Ramírez', servicio: 'Barba + corte', estado: 'confirmado', dur: '60 min' },
                    { hora: '11:30', nombre: 'Ana Lucía Torres', servicio: 'Peinado', estado: 'pendiente', dur: '30 min' },
                    { hora: '14:00', nombre: 'Diego Martínez', servicio: 'Corte de cabello', estado: 'confirmado', dur: '45 min' },
                  ].map(({ hora, nombre, servicio, estado, dur }) => (
                    <div class="flex items-center gap-3 p-2.5 bg-dark rounded-lg border border-dark-tertiary hover:border-blue-500/30 transition-colors">
                      <div class="text-center w-12 flex-shrink-0">
                        <span class="text-blue-400 text-xs font-bold font-mono">{hora}</span>
                        <span class="block text-gray-600 text-[9px]">{dur}</span>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="text-white text-xs font-semibold truncate">{nombre}</div>
                        <div class="text-gray-500 text-[10px]">{servicio}</div>
                      </div>
                      <span class={`text-[9px] px-2 py-0.5 rounded-full flex-shrink-0 ${estado === 'confirmado' ? 'bg-green-500/20 text-green-400 border border-green-500/30' : 'bg-yellow-500/20 text-yellow-400 border border-yellow-500/30'}`}>
                        {estado}
                      </span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Botón agregar turno -->
              <button class="w-full py-2.5 border-2 border-dashed border-blue-500/30 text-blue-400 text-sm rounded-xl hover:bg-blue-600/10 transition-colors flex items-center justify-center gap-2">
                <i class="fas fa-plus text-xs"></i>
                Nuevo turno manual
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cómo funciona -->
  <section class="py-20 bg-dark-secondary">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 font-display">
        ¿Cómo funciona para <span class="text-blue-400">tu cliente</span>?
      </h2>
      <p class="text-center text-gray-400 mb-14 max-w-xl mx-auto">
        En 3 simples pasos, tu cliente saca su turno sin llamarte
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto mb-16">
        {[
          { paso: '01', icon: 'fas fa-globe', title: 'Entra a tu web', desc: 'Tu cliente visita tu página y hace clic en "Reservar turno".' },
          { paso: '02', icon: 'fas fa-calendar-alt', title: 'Elige día y hora', desc: 'Ve los horarios disponibles en tiempo real y elige el que le sirve.' },
          { paso: '03', icon: 'fab fa-whatsapp', title: 'Confirma por WhatsApp', desc: 'Recibe una confirmación automática con el detalle del turno reservado.' },
        ].map(({ paso, icon, title, desc }) => (
          <div class="text-center">
            <div class="relative inline-flex mb-6">
              <div class="w-16 h-16 bg-blue-600/15 rounded-2xl flex items-center justify-center border border-blue-500/25 mx-auto">
                <i class={`${icon} text-blue-400 text-2xl`}></i>
              </div>
              <span class="absolute -top-2 -right-2 w-6 h-6 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold">{paso.replace('0', '')}</span>
            </div>
            <h3 class="font-bold text-white mb-2 font-display text-lg">{title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Funcionalidades -->
  <section class="py-20 bg-dark">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-14 font-display">
        Todo lo que necesitás para <span class="text-blue-400">gestionar tu agenda</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {[
          { icon: 'fas fa-clock', title: 'Disponibilidad configurable', desc: 'Definís tus horarios de atención y días libres. El sistema los aplica automáticamente.' },
          { icon: 'fas fa-bell', title: 'Recordatorios automáticos', desc: 'Mensajes de WhatsApp automáticos para confirmar o recordar turnos próximos.' },
          { icon: 'fas fa-users', title: 'Panel del negocio', desc: 'Vista completa de toda tu agenda: pendientes, confirmados, cancelados.' },
          { icon: 'fas fa-cut', title: 'Múltiples servicios', desc: 'Configurá todos tus servicios con duración y precio. El sistema calcula la disponibilidad.' },
          { icon: 'fas fa-ban', title: 'Cancelaciones sin drama', desc: 'Tus clientes pueden cancelar y el horario queda libre automáticamente.' },
          { icon: 'fas fa-chart-line', title: 'Reportes de agenda', desc: 'Visualizá cuántos turnos tuviste, cuáles se cumplieron, promedios por día.' },
        ].map(({ icon, title, desc }) => (
          <div class="bg-dark-secondary p-6 rounded-xl border border-dark-tertiary hover:border-blue-500/40 transition-all duration-300 group">
            <div class="w-10 h-10 bg-blue-600/15 rounded-xl flex items-center justify-center border border-blue-500/25 mb-4 group-hover:bg-blue-600/25 transition-colors">
              <i class={`${icon} text-blue-400`}></i>
            </div>
            <h3 class="font-bold text-white mb-2 font-display">{title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ¿Para quién? -->
  <section class="py-20 bg-dark-secondary">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-14 font-display">¿Para quién es ideal?</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
        {[
          { icon: 'fas fa-cut', label: 'Peluquerías' },
          { icon: 'fas fa-spa', label: 'Estética' },
          { icon: 'fas fa-tooth', label: 'Odontología' },
          { icon: 'fas fa-dumbbell', label: 'Personal trainers' },
          { icon: 'fas fa-user-md', label: 'Profesionales de salud' },
          { icon: 'fas fa-car', label: 'Talleres mecánicos' },
          { icon: 'fas fa-paw', label: 'Veterinarias' },
          { icon: 'fas fa-ellipsis-h', label: 'Y más...' },
        ].map(({ icon, label }) => (
          <div class="bg-dark p-4 rounded-xl border border-dark-tertiary text-center hover:border-blue-500/40 transition-all duration-300">
            <i class={`${icon} text-blue-400 text-xl mb-2 block`}></i>
            <span class="text-gray-400 text-sm">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-dark">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 font-display">
        Incluido en el plan <span class="text-blue-400">Landing + Turnos</span>
      </h2>
      <p class="text-gray-400 mb-8 max-w-xl mx-auto">
        Por $50.000/mes tenés tu landing page profesional + sistema de turnos completo + soporte incluido.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="https://wa.me/3834944727" target="_blank" rel="noopener noreferrer"
          class="px-8 py-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-500 transition-all duration-300 hover:scale-105 flex items-center gap-3">
          <i class="fab fa-whatsapp"></i>
          Solicitar demo personalizada
        </a>
        <a href="/#planes"
          class="px-8 py-4 border-2 border-blue-500/50 text-blue-300 font-bold rounded-xl hover:bg-blue-600/10 transition-all duration-300 flex items-center gap-2">
          <i class="fas fa-tags"></i>
          Ver todos los planes
        </a>
      </div>
      <p class="text-gray-600 text-sm mt-6">
        ← <a href="/#productos" class="text-gray-500 hover:text-primary transition-colors">Volver a productos</a>
        &nbsp;|&nbsp;
        <a href="/#planes" class="text-gray-500 hover:text-primary transition-colors">Ver todos los planes →</a>
      </p>
    </div>
  </section>

</Layout>