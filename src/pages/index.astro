---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';

const services = [
  {
    icon: 'fas fa-rocket',
    title: 'Landing Pages',
    description: 'Sitios simples, rápidos y optimizados para conversión. Perfectos para lanzar tu negocio online.',
    technologies: ['Astro', 'HTML/CSS/JavaScript', 'Tailwind o Bootstrap', 'SEO optimizado', 'Máxima velocidad'],
    price: 'Desde $150.000',
    priceNote: 'Incluye diseño responsive, SEO y formulario'
  },
  {
    icon: 'fas fa-building',
    title: 'Webs Corporativas',
    description: 'Sitios profesionales para tu empresa con administración de contenido y formularios.',
    technologies: ['Astro o Next.js', 'Hasta 5 secciones', 'Integraciones básicas', 'Formularios de contacto', 'Diseño personalizado'],
    price: 'Desde $300.000',
    priceNote: 'Diseño a medida y responsive'
  },
  {
    icon: 'fas fa-shopping-cart',
    title: 'Tiendas Online',
    description: 'E-commerce completo con carrito, pagos y panel de administración.',
    technologies: ['Next.js', 'Supabase o SQL', 'Medios de pago', 'Panel administrativo', 'Catálogo y carrito'],
    price: 'Desde $500.000',
    priceNote: 'Base de datos incluida'
  },
  {
    icon: 'fas fa-cogs',
    title: 'Sistemas a Medida',
    description: 'Soluciones personalizadas según las necesidades específicas de tu negocio.',
    technologies: ['Next.js', 'Supabase', 'Node.js o PHP', 'Autenticación y roles', 'Escalabilidad'],
    price: 'A cotizar',
    priceNote: 'Según alcance del proyecto'
  }
];

const projects = [
  {
    icon: 'fas fa-shopping-bag',
    title: 'JMR E-commerce',
    category: 'E-commerce',
    technologies: ['Next.js', 'SQL', 'Tailwind'],
    demoUrl: 'https://www.jmrmarroquineria.com.ar/',
  },
  {
    icon: 'fas fa-boxes',
    title: 'Devhub POS',
    category: 'Sistema de Gestión',
    technologies: ['Next.js', 'Supabase', 'TypeScript'],
    demoUrl: 'https://devhub-pos.vercel.app/',
  },
  {
    icon: 'fas fa-home',
    title: 'Vista Montaña',
    category: 'Web Corporativa',
    technologies: ['Next.js', 'Tailwind', 'WhatsApp API'],
    demoUrl: 'https://vista-montana.vercel.app/',
  },
];
---

<Layout title="DevHub | Agencia de Desarrollo de Software en Argentina — Landing Pages, E-commerce y Sistemas a Medida">
  
<!-- Planes DevHub -->
<section class="py-20 bg-dark-primary relative overflow-hidden">
  <div class="container mx-auto px-4">
    <p class="text-center text-xs uppercase tracking-widest text-gray-500 mb-2 animate-on-scroll opacity-0">
      Planes
    </p>
    <h2 class="text-4xl md:text-5xl font-bold text-center mb-4 animate-on-scroll opacity-0 font-display">
      Elegí tu plan
    </h2>
    <p class="text-center text-gray-400 mb-16 animate-on-scroll opacity-0">
      Todo lo que necesita tu negocio, en un solo lugar
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">

      <!-- Plan Landing + Turnos -->
      <div class="animate-on-scroll opacity-0 bg-dark rounded-xl border border-dark-tertiary hover:border-blue-500/50 transition-all duration-500 hover:-translate-y-2 overflow-hidden flex flex-col">
        <div class="h-1 bg-blue-600 w-full"></div>
        <div class="p-8 flex flex-col flex-1">
          <span class="text-xs px-3 py-1 bg-blue-600/20 text-blue-300 rounded-full border border-blue-500/30 mb-4 inline-block w-fit">
            Gestión de turnos
          </span>
          <h3 class="text-2xl font-bold text-blue-400 mb-2 font-display">Landing + Turnos</h3>
          <div class="flex items-baseline gap-1 mb-4">
            <span class="text-4xl font-bold text-white">$50.000</span>
            <span class="text-gray-500 text-sm">/mes</span>
          </div>
          <p class="text-gray-400 text-sm mb-6">Ideal para profesionales y servicios que quieren presencia online y gestión de turnos.</p>
          <ul class="space-y-2 mb-8 flex-1">
            {['Página web profesional', 'Servicios / Fotos / Ubicación', 'Botón WhatsApp', 'Sistema de turnos online', 'Panel administrador', 'Soporte y mantenimiento'].map(f => (
              <li class="flex items-center gap-3 text-sm text-gray-400">
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>
                {f}
              </li>
            ))}
          </ul>
          <a href="https://wa.me/3834944727" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-500 transition-all duration-300">
            Contratar plan
          </a>
        </div>
      </div>

      <!-- Plan Landing + POS -->
      <div class="animate-on-scroll opacity-0 bg-dark rounded-xl border border-dark-tertiary hover:border-red-500/50 transition-all duration-500 hover:-translate-y-2 overflow-hidden flex flex-col" style="animation-delay: 0.1s">
        <div class="h-1 bg-red-600 w-full"></div>
        <div class="p-8 flex flex-col flex-1">
          <span class="text-xs px-3 py-1 bg-red-600/20 text-red-300 rounded-full border border-red-500/30 mb-4 inline-block w-fit">
            Punto de venta
          </span>
          <h3 class="text-2xl font-bold text-red-400 mb-2 font-display">Landing + POS</h3>
          <div class="flex items-baseline gap-1 mb-4">
            <span class="text-4xl font-bold text-white">$50.000</span>
            <span class="text-gray-500 text-sm">/mes</span>
          </div>
          <p class="text-gray-400 text-sm mb-6">Ideal para negocios que venden productos y quieren presencia online.</p>
          <ul class="space-y-2 mb-8 flex-1">
            {['Página web profesional', 'Catálogo de productos', 'Fotos / Precios / Ubicación', 'Botón WhatsApp', 'Sistema DevHub POS', 'Caja, ventas y stock', 'Panel administrador', 'Soporte y mantenimiento'].map(f => (
              <li class="flex items-center gap-3 text-sm text-gray-400">
                <span class="w-1.5 h-1.5 rounded-full bg-red-500 flex-shrink: 0"></span>
                {f}
              </li>
            ))}
          </ul>
          <a href="https://wa.me/3834944727" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-red-600 text-white font-bold rounded-lg hover:bg-red-500 transition-all duration-300">
            Contratar plan
          </a>
        </div>
      </div>

      <!-- Plan Landing + Gourmet -->
      <div class="animate-on-scroll opacity-0 bg-dark rounded-xl border-2 border-yellow-600/60 hover:border-yellow-500 transition-all duration-500 hover:-translate-y-2 overflow-hidden flex flex-col relative" style="animation-delay: 0.2s">
        <div class="absolute top-3 right-3 text-xs px-3 py-1 bg-amber-500/10 text-amber-300 rounded-full border border-amber-500/30">Premium</div>
        <div class="h-1 bg-gradient-to-r from-amber-700 via-amber-500 to-yellow-400 w-full"></div>
        <div class="p-8 flex flex-col flex-1">
          <span class="text-xs px-3 py-1 bg-amber-700/20 text-amber-300 rounded-full border border-amber-600/30 mb-4 inline-block w-fit">
            Gestión gastronómica
          </span>
          <h3 class="text-2xl font-bold text-yellow-400 mb-2 font-display">Landing + Gourmet</h3>
          <div class="flex items-baseline gap-1 mb-4">
            <span class="text-4xl font-bold text-white">$60.000</span>
            <span class="text-gray-500 text-sm">/mes</span>
          </div>
          <p class="text-gray-400 text-sm mb-6">Ideal para restaurantes y locales gastronómicos que quieren control total de su operación.</p>
          <ul class="space-y-2 mb-8 flex-1">
            {['Página web profesional', 'Carta digital para clientes', 'Fotos / Menú / Ubicación', 'Botón WhatsApp', 'Sistema DevHub Gourmet', 'Control de mesas en tiempo real', 'Gestión de pedidos por mesa', 'Cobranzas y caja integradas', 'Panel administrador', 'Soporte y mantenimiento'].map(f => (
              <li class="flex items-center gap-3 text-sm text-gray-400">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500 flex-shrink-0"></span>
                {f}
              </li>
            ))}
          </ul>
          <a href="https://wa.me/3834944727" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-amber-600 text-white font-bold rounded-lg hover:bg-amber-500 transition-all duration-300">
            Contratar plan
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
  <!-- Servicios preview -->
  <section class="py-20 bg-dark relative overflow-hidden">
    <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="container mx-auto px-4 relative z-10">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-4 animate-on-scroll opacity-0 font-display">
        Nuestros <span class="text-primary">Servicios</span>
      </h2>
      <p class="text-center text-gray-400 mb-16 animate-on-scroll opacity-0">
        Soluciones tecnológicas a medida para cada necesidad
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
        {services.map((service, i) => (
          <div class="animate-on-scroll opacity-0" style={`animation-delay: ${i * 0.1}s`}>
            <ServiceCard {...service} />
          </div>
        ))}
      </div>
      <div class="text-center animate-on-scroll opacity-0">
        <a href="/servicios" class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-dark font-bold rounded-lg hover:bg-primary-dark transition-all duration-300 hover:scale-105">
          <i class="fas fa-arrow-right"></i>
          Ver todos los servicios con detalles
        </a>
      </div>
    </div>
  </section>

  

  <!-- Por qué DevHub - versión compacta -->
  <section class="py-20 bg-dark-secondary relative overflow-hidden">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-4 animate-on-scroll opacity-0 font-display">
        ¿Por qué <span class="text-primary">DevHub</span>?
      </h2>
      <p class="text-center text-gray-400 mb-16 animate-on-scroll opacity-0">
        La diferencia entre una plantilla y un sitio a medida
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-12">
        {[
          { icon: 'fas fa-tachometer-alt', stat: '+300%', title: 'Velocidad', desc: 'Hasta 10x más rápidos que Wix o Tienda Nube. Google premia la velocidad.' },
          { icon: 'fas fa-crown', stat: '100%', title: 'Tuyo', desc: 'El código es 100% tuyo. No dependés de plataformas que cambian precios o cierran.' },
          { icon: 'fas fa-dollar-sign', stat: '0$/mes', title: 'Sin suscripción', desc: 'Pago único vs. suscripciones mensuales eternas. En 1-2 años ya ahorraste.' },
          { icon: 'fas fa-search', stat: 'Top 10', title: 'SEO Profesional', desc: 'Optimización técnica profunda imposible con plantillas genéricas.' },
          { icon: 'fas fa-infinity', stat: '∞', title: 'Sin Límites', desc: 'Crecé sin restricciones. Sin planes premium ni funciones bloqueadas.' },
          { icon: 'fas fa-map-marker-alt', stat: 'Local', title: 'Equipo Catamarca', desc: 'Reuniones presenciales posibles. Entendemos el mercado local.' },
        ].map((item, i) => (
          <div class="group bg-dark p-6 rounded-xl border-2 border-transparent hover:border-primary transition-all duration-500 hover:-translate-y-2 animate-on-scroll opacity-0 relative overflow-hidden" style={`animation-delay: ${i * 0.1}s`}>
            <div class="absolute top-0 right-0 bg-primary/20 text-primary px-3 py-1 rounded-bl-lg rounded-tr-lg font-bold text-sm border border-primary/30">
              {item.stat}
            </div>
            <div class="text-4xl mb-3 mt-3 group-hover:scale-110 transition-transform duration-300 inline-block">
              <i class={`${item.icon} text-primary`}></i>
            </div>
            <h3 class="text-lg font-bold text-primary mb-2 font-display">{item.title}</h3>
            <p class="text-gray-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center animate-on-scroll opacity-0">
        <a href="/servicios#ventajas" class="inline-flex items-center gap-2 text-primary font-semibold hover:underline">
          <i class="fas fa-chart-line"></i>
          Ver comparación completa vs. Wix y Tienda Nube
        </a>
      </div>
    </div>
  </section>

  <!-- Proyectos preview -->
  <section class="py-20 bg-dark relative overflow-hidden">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-4 animate-on-scroll opacity-0 font-display">
        Proyectos <span class="text-primary">Reales</span>
      </h2>
      <p class="text-center text-gray-400 mb-16 animate-on-scroll opacity-0">
        Resultados concretos para negocios reales
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto mb-12">
        {projects.map((p, i) => (
          <a
            href={p.demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-dark-secondary p-6 rounded-xl border-2 border-transparent hover:border-primary transition-all duration-500 hover:-translate-y-3 hover:shadow-xl hover:shadow-primary/20 animate-on-scroll opacity-0 block"
            style={`animation-delay: ${i * 0.12}s`}
          >
            <div class="flex items-start justify-between mb-4">
              <div class="text-4xl group-hover:scale-110 transition-transform duration-300">
                <i class={`${p.icon} text-primary`}></i>
              </div>
              <span class="text-xs px-3 py-1 bg-primary/20 text-primary rounded-full border border-primary/30">
                {p.category}
              </span>
            </div>
            <h3 class="text-xl font-bold text-primary mb-3 font-display">{p.title}</h3>
            <div class="flex flex-wrap gap-2 mb-4">
              {p.technologies.map(t => (
                <span class="text-xs px-2 py-1 bg-dark rounded-full text-gray-400 border border-dark-tertiary">{t}</span>
              ))}
            </div>
            <span class="inline-flex items-center gap-2 text-primary text-sm font-semibold group-hover:underline">
              <i class="fas fa-external-link-alt text-xs"></i>
              Ver en vivo
            </span>
          </a>
        ))}
      </div>
      <div class="text-center animate-on-scroll opacity-0">
        <a href="/proyectos" class="inline-flex items-center gap-2 px-8 py-4 border-2 border-primary text-primary font-bold rounded-lg hover:bg-primary hover:text-dark transition-all duration-300 hover:scale-105">
          <i class="fas fa-folder-open"></i>
          Ver portfolio completo (8 proyectos)
        </a>
      </div>
    </div>
  </section>

  <!-- Blog preview -->
  <section class="py-20 bg-dark-secondary relative overflow-hidden">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-4 animate-on-scroll opacity-0 font-display">
        Del <span class="text-primary">Blog</span>
      </h2>
      <p class="text-center text-gray-400 mb-16 animate-on-scroll opacity-0">
        Recursos y guías para negocios que quieren crecer online
      </p>
      <div class="max-w-3xl mx-auto">
        <a href="/blog/wix-vs-desarrollo-a-medida" class="group bg-dark p-8 rounded-2xl border-2 border-transparent hover:border-primary transition-all duration-500 hover:shadow-xl hover:shadow-primary/20 block animate-on-scroll opacity-0">
          <div class="flex flex-wrap gap-3 mb-4">
            <span class="text-xs px-3 py-1 bg-primary/20 text-primary rounded-full border border-primary/30">⭐ Artículo Destacado</span>
            <span class="text-xs px-3 py-1 bg-dark-secondary text-gray-400 rounded-full border border-dark-tertiary">15 min lectura</span>
            <span class="text-xs px-3 py-1 bg-dark-secondary text-gray-400 rounded-full border border-dark-tertiary">SEO</span>
          </div>
          <h3 class="text-2xl font-bold text-primary mb-3 group-hover:underline font-display">
            ¿Wix, Tienda Nube o Desarrollo a Medida? La Guía Definitiva 2025
          </h3>
          <p class="text-gray-300 mb-4">
            Comparamos en detalle las 3 opciones para que puedas tomar la mejor decisión para tu negocio. Velocidad, SEO, costos reales y casos de uso concretos.
          </p>
          <span class="inline-flex items-center gap-2 text-primary font-semibold">
            Leer artículo completo <i class="fas fa-arrow-right"></i>
          </span>
        </a>
      </div>
      <div class="text-center mt-8 animate-on-scroll opacity-0">
        <a href="/blog" class="inline-flex items-center gap-2 text-primary font-semibold hover:underline">
          <i class="fas fa-newspaper"></i>
          Ver todos los artículos
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-20 bg-dark relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl"></div>
    <div class="container mx-auto px-4 text-center relative z-10">
      <h2 class="text-4xl md:text-6xl font-bold mb-6 animate-on-scroll opacity-0 font-display">
        ¿Listo para tener tu <span class="text-primary">sitio profesional</span>?
      </h2>
      <p class="text-xl text-gray-300 mb-10 max-w-2xl mx-auto animate-on-scroll opacity-0">
        Contanos tu idea y te respondemos en menos de 24hs con una propuesta personalizada.
      </p>
      <div class="flex flex-wrap justify-center gap-4 animate-on-scroll opacity-0">
        <a
          href="https://wa.me/5493834946767"
          target="_blank"
          rel="noopener noreferrer"
          class="px-10 py-5 bg-primary text-dark font-bold rounded-xl text-lg hover:bg-primary-dark transition-all duration-300 hover:scale-105 shadow-lg hover:shadow-primary/50 flex items-center gap-3"
        >
          <i class="fab fa-whatsapp text-xl"></i>
          Hablar por WhatsApp
        </a>
        <a
          href="/contacto"
          class="px-10 py-5 border-2 border-primary text-primary font-bold rounded-xl text-lg hover:bg-primary/10 transition-all duration-300 hover:scale-105 flex items-center gap-3"
        >
          <i class="fas fa-paper-plane"></i>
          Enviar consulta
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes scroll-reveal {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-on-scroll { animation: scroll-reveal 0.8s ease-out forwards; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('animate-on-scroll');
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -80px 0px' });

  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>