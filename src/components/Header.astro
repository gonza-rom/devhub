---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', text: 'Inicio' },
  { href: '/servicios', text: 'Servicios' },
  {
    href: '/productos',
    text: 'Productos',
    dropdown: [
      { href: '/productos', text: 'Todos los productos', icon: 'fas fa-cube', desc: 'Ver catálogo completo' },
      { href: '/productos/pos', text: 'DevHub POS', icon: 'fas fa-cash-register', desc: 'Punto de venta', color: 'text-red-400' },
      { href: '/productos/turnos', text: 'DevHub Turnos', icon: 'fas fa-calendar-check', desc: 'Agenda online', color: 'text-blue-400' },
      { href: '/productos/gourmet', text: 'DevHub Gourmet', icon: 'fas fa-utensils', desc: 'Gestión gastronómica', color: 'text-amber-400' },
    ],
  },
  { href: '/proyectos', text: 'Proyectos' },
  { href: '/nosotros', text: 'Nosotros' },
  { href: '/blog', text: 'Blog' },
  { href: '/contacto', text: 'Contacto' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-dark-secondary/95 backdrop-blur-md shadow-lg shadow-primary/10 transition-colors duration-300 border-b border-dark-tertiary">
  <nav class="container mx-auto px-4 py-4">
    <div class="flex justify-between items-center">
      <a href="/" class="flex items-center gap-3 group">
        <img
          src="/logo-bg.png"
          alt="DevHub"
          class="h-12 md:h-14 transition-all duration-300 group-hover:scale-110 group-hover:drop-shadow-[0_0_15px_rgba(255,193,7,0.8)]"
        />
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center gap-6">
        {navLinks.map(link => (
          <li class={link.dropdown ? 'relative group/nav flex items-center' : 'flex items-center'}>
            {link.dropdown ? (
              <!-- Link con dropdown -->
              <div>
                <button
                  class={`flex items-center gap-1.5 font-medium transition-colors pb-1 border-b-2 leading-none ${
                    isActive(link.href)
                      ? 'text-primary border-primary'
                      : 'text-gray-300 hover:text-primary border-transparent hover:border-primary/50'
                  }`}
                >
                  {link.text}
                  <i class="fas fa-chevron-down text-[10px] transition-transform duration-300 group-hover/nav:rotate-180"></i>
                </button>

                <!-- Dropdown panel -->
                <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover/nav:opacity-100 group-hover/nav:visible transition-all duration-200 translate-y-1 group-hover/nav:translate-y-0 w-64">
                  <div class="bg-dark-secondary border border-dark-tertiary rounded-2xl shadow-2xl shadow-black/40 overflow-hidden">
                    <!-- Header del dropdown -->
                    <div class="px-4 pt-3 pb-2 border-b border-dark-tertiary">
                      <span class="text-xs text-gray-600 uppercase tracking-widest font-semibold">Plataformas</span>
                    </div>
                    <div class="p-2">
                      {link.dropdown.map((item, idx) => (
                        <a href={item.href}
                          class={`flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-200 hover:bg-dark group/item ${
                            isActive(item.href) && item.href !== '/productos' ? 'bg-dark' : ''
                          } ${idx === 0 ? 'mb-1' : ''}`}
                        >
                          <div class={`w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 ${
                            idx === 0
                              ? 'bg-primary/10 border border-primary/20'
                              : item.color === 'text-red-400'
                              ? 'bg-red-600/15 border border-red-500/20'
                              : item.color === 'text-blue-400'
                              ? 'bg-blue-600/15 border border-blue-500/20'
                              : 'bg-amber-600/15 border border-amber-500/20'
                          }`}>
                            <i class={`${item.icon} text-xs ${idx === 0 ? 'text-primary' : item.color ?? 'text-gray-400'}`}></i>
                          </div>
                          <div class="min-w-0">
                            <div class={`text-sm font-semibold ${idx === 0 ? 'text-white' : item.color ?? 'text-gray-300'}`}>{item.text}</div>
                            <div class="text-xs text-gray-600">{item.desc}</div>
                          </div>
                          {idx === 0 && (
                            <i class="fas fa-arrow-right text-[10px] text-primary ml-auto opacity-0 group-hover/item:opacity-100 transition-opacity -translate-x-1 group-hover/item:translate-x-0 transition-transform"></i>
                          )}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={link.href}
                class={`font-medium transition-colors pb-1 border-b-2 ${
                  isActive(link.href)
                    ? 'text-primary border-primary'
                    : 'text-gray-300 hover:text-primary border-transparent hover:border-primary/50'
                }`}
              >
                {link.text}
              </a>
            )}
          </li>
        ))}
        <li>
          <a
            href="https://wa.me/5493834946767"
            target="_blank"
            rel="noopener noreferrer"
            class="px-5 py-2 bg-primary text-dark font-bold rounded-lg hover:bg-primary-dark transition-all duration-300 hover:scale-105 flex items-center gap-2 text-sm"
          >
            <i class="fab fa-whatsapp"></i>
            <span>WhatsApp</span>
          </a>
        </li>
      </ul>

      <!-- Mobile Menu Button -->
      <button
        id="mobileMenuBtn"
        class="md:hidden w-10 h-10 flex flex-col justify-center items-center gap-1.5 relative"
        aria-label="Toggle menu"
      >
        <span id="line1" class="w-6 h-0.5 bg-primary block transition-all duration-300 origin-center"></span>
        <span id="line2" class="w-6 h-0.5 bg-primary block transition-all duration-300 origin-center"></span>
        <span id="line3" class="w-6 h-0.5 bg-primary block transition-all duration-300 origin-center"></span>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div
      id="mobileMenu"
      class="md:hidden overflow-hidden transition-all duration-300 ease-in-out"
      style="max-height: 0; opacity: 0;"
    >
      <div class="pt-6 pb-6 border-t border-dark-tertiary mt-4">
        <ul class="flex flex-col items-center gap-1">

          {navLinks.map(link => (
            link.dropdown ? (
              <!-- Sección especial productos en mobile -->
              <li class="w-full">
                <div class="text-center mb-3 mt-2">
                  <span class="text-xs text-gray-600 uppercase tracking-widest font-semibold">Productos</span>
                </div>
                <div class="grid grid-cols-3 gap-2 px-4 mb-2">
                  {link.dropdown.filter(i => i.href !== '/productos').map(item => (
                    <a href={item.href}
                      class="flex flex-col items-center gap-1.5 p-3 bg-dark rounded-xl border border-dark-tertiary hover:border-primary/30 transition-all duration-200 text-center">
                      <i class={`${item.icon} text-lg ${item.color ?? 'text-primary'}`}></i>
                      <span class="text-[10px] text-gray-400 font-semibold leading-tight">{item.text.replace('DevHub ', '')}</span>
                    </a>
                  ))}
                </div>
                <a href="/productos"
                  class="block text-center text-primary text-sm font-semibold py-2 hover:underline">
                  Ver todos los productos →
                </a>
              </li>
            ) : (
              <li class="w-full text-center">
                <a
                  href={link.href}
                  class={`block font-medium text-lg transition-colors py-2.5 ${
                    isActive(link.href) ? 'text-primary' : 'text-gray-300 hover:text-primary'
                  }`}
                >
                  {link.text}
                </a>
              </li>
            )
          ))}

          <li class="pt-3">
            <a
              href="https://wa.me/5493834946767"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-dark font-bold rounded-lg hover:bg-primary-dark transition-all duration-300"
            >
              <i class="fab fa-whatsapp"></i>
              WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobileMenuBtn');
  const menu = document.getElementById('mobileMenu') as HTMLElement;
  const line1 = document.getElementById('line1') as HTMLElement;
  const line2 = document.getElementById('line2') as HTMLElement;
  const line3 = document.getElementById('line3') as HTMLElement;

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    line1.style.transform = 'translateY(8px) rotate(45deg)';
    line2.style.opacity = '0';
    line2.style.transform = 'scaleX(0)';
    line3.style.transform = 'translateY(-8px) rotate(-45deg)';
    menu.style.maxHeight = menu.scrollHeight + 'px';
    menu.style.opacity = '1';
    btn?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    isOpen = false;
    line1.style.transform = '';
    line2.style.opacity = '1';
    line2.style.transform = '';
    line3.style.transform = '';
    menu.style.maxHeight = '0';
    menu.style.opacity = '0';
    btn?.setAttribute('aria-expanded', 'false');
  }

  btn?.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
  menu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
  window.addEventListener('resize', () => { if (window.innerWidth >= 768 && isOpen) closeMenu(); });
</script>